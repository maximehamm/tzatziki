<idea-plugin>

    <!--
    Activated only when the `cucumber-javascript` Marketplace plugin is present
    (the `<depends optional="true" config-file=...>` in plugin.xml triggers on it).
    cucumber-javascript depends on `com.intellij.modules.javascript`, so the
    `JavaScript` plugin — whose PSI we use here — is guaranteed loaded too; we keep
    the explicit `<depends>JavaScript</depends>` for clarity. Cucumber+ falls back
    gracefully on IntelliJ IDEA Community / setups without these plugins.
    -->
    <depends>JavaScript</depends>

    <extensions defaultExtensionNs="io.nimbly.tzatziki">
        <io.nimbly.tzatziki.main implementation="io.nimbly.tzatziki.JsTzatzikiExtensionPoint"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- JS/TS counterpart of TzCucumberCodeBreakpointType — gives the green
             Cucumber+ badge to step-def breakpoints on .js / .ts files instead of
             the platform's native red dot. -->
        <xdebugger.breakpointType implementation="io.nimbly.tzatziki.breakpoints.TzCucumberJsBreakpointType"/>
        <!-- "N scenarios" gutter marker on JS / TS step definitions, mirroring
             JavaTzatzikiUsagesMarker / KotlinTzatzikiUsagesMarker.
             Registered for JavaScript ONLY: TypeScript is a JavaScript dialect,
             so the provider runs on .ts files too via base-language lookup.
             Registering BOTH languages made it fire twice on .ts → two duplicate
             gutter markers (the "2 Given / 2 Given" chooser popup). -->
        <codeInsight.lineMarkerProvider language="JavaScript"
                implementationClass="io.nimbly.tzatziki.JsTzatzikiUsagesMarker"/>
        <!-- Forces a cucumber-js step-def reindex at project start. Compensates
             for a sandbox-only quirk where the cucumber-javascript stub cache
             survives plugin-tzatziki rebuilds but the cached stubs become
             unreadable until `Invalidate Caches` is run manually. -->
        <postStartupActivity implementation="io.nimbly.tzatziki.JsCucumberIndexRefresher"/>
        <!-- Populates the cucumberExecutionTracker from SMTRunner events because
             the JS test framework swallows TeamCity messages before they reach
             our stdout-based ProcessListener (which is how cucumber-jvm fills it). -->
        <postStartupActivity implementation="io.nimbly.tzatziki.run.TzNodeExecutionTrackerListener"/>
    </extensions>

    <projectListeners>
        <!-- JS / TS counterpart of TzRunCodeListener: filters Node debug pauses
             so the debugger only stops on the example row the user flagged in
             the .feature (instead of breaking on every Scenario Outline iteration). -->
        <listener class="io.nimbly.tzatziki.run.TzRunNodeListener"
                  topic="com.intellij.xdebugger.XDebuggerManagerListener"/>
    </projectListeners>

</idea-plugin>
